{
  "manifest_version": 3,
  "name": "B站自定义倍速",
  "version": "1.1",
  "description": "突破倍速限制，支持任意倍速，支持换集/刷新自动记忆。",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.bilibili.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/video/*", "*://*.bilibili.com/bangumi/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}